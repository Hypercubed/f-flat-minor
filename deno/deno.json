{
  "compilerOptions": {
    "strict": true
  },
  "imports": {
    "std/": "https://deno.land/std@0.224.0/"
  },
  "tasks": {
    "run": "deno run --allow-read --allow-env",
    "compile": "deno compile --allow-read --allow-env",
    "test": "deno test --allow-read --allow-env"
  },
  "lint": {
    "include": ["src/", "bin/"]
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "include": ["src/", "bin/"]
  }
}
