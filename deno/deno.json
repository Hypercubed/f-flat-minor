{
  "compilerOptions": {
    "strict": true
  },
  "imports": {
    "std/": "https://deno.land/std@0.224.0/"
  },
  "tasks": {
    "build": "deno task build:*",
    "build:compile": {
      "command": "deno compile --allow-env --allow-read -o build/ff-compile bin/ff-compile.ts",
      "description": "Compile the compiler to a standalone executable."
    },
    "build:execute": {
      "command": "deno compile --allow-env --allow-read -o build/ff-execute bin/ff-execute.ts",
      "description": "Compile the executor to a standalone executable."
    },
    "build:preprocess": {
      "command": "deno compile --allow-env --allow-read -o build/ff-preprocess bin/ff-preprocess.ts",
      "description": "Compile the preprocessor to a standalone executable."
    },
    "build:run": {
      "command": "deno compile --allow-env --allow-read -o build/ff-run bin/ff-run.ts",
      "description": "Compile the runner to a standalone executable."
    },
    "ff:run": "deno run --no-check --allow-read --allow-env bin/ff-run.ts",
    "ff:compile": "deno run --no-check --allow-read bin/ff-compile.ts",
    "ff:execute": "deno run --no-check --allow-read --allow-env bin/ff-execute.ts",
    "ff:preprocess": "deno run --no-check --allow-read bin/ff-preprocess.ts",
    "ff:repl": "deno run --no-check --allow-read --allow-env bin/ff-repl.ts"
  },
  "lint": {
    "include": ["src/", "bin/"]
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "include": ["src/", "bin/"]
  }
}
