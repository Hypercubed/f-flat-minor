---
import { navItems } from "../data/site";
import "../styles/legacy-web.css";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  theme?: string;
  activePath?: string;
}

const {
  title,
  description,
  theme = "home",
  activePath = Astro.url.pathname,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | F♭m</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class={`theme-${theme}`}>
    <main class="main-shell">
      <header class="site-header">
        <a class="brand-link" href="/">
          <img class="brand-mark" src="/logo.svg" alt="Fbm logo" width="44" height="44" />
          <span class="brand-copy">
            <strong>f-flat-minor</strong>
          </span>
        </a>
        <div class="site-header-actions">
          <nav class="site-nav" aria-label="Primary">
            {
              navItems.map((item) => (
                <a class:list={["nav-link", item.href === activePath && "is-active"]} href={item.href}>
                  {item.label}
                </a>
              ))
            }
          </nav>
          <a
            class="repo-link"
            href="https://github.com/Hypercubed/f-flat-minor"
            target="_blank"
            rel="noreferrer"
            aria-label="View the GitHub repository"
            title="View the GitHub repository"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path
                fill="currentColor"
                d="M12 0.5C5.649 0.5 0.5 5.649 0.5 12c0 5.082 3.292 9.395 7.861 10.916c0.575 0.106 0.786-0.249 0.786-0.554c0-0.274-0.01-1-0.016-1.962c-3.198 0.695-3.873-1.541-3.873-1.541c-0.523-1.328-1.277-1.682-1.277-1.682c-1.044-0.714 0.079-0.699 0.079-0.699c1.154 0.081 1.761 1.185 1.761 1.185c1.026 1.758 2.692 1.25 3.348 0.956c0.104-0.743 0.401-1.25 0.729-1.537c-2.553-0.291-5.238-1.276-5.238-5.679c0-1.254 0.448-2.28 1.183-3.084c-0.119-0.29-0.513-1.46 0.112-3.045c0 0 0.965-0.309 3.162 1.178c0.917-0.255 1.9-0.382 2.878-0.387c0.977 0.005 1.961 0.132 2.879 0.387c2.195-1.487 3.158-1.178 3.158-1.178c0.627 1.585 0.233 2.755 0.115 3.045c0.736 0.804 1.181 1.83 1.181 3.084c0 4.414-2.689 5.385-5.252 5.67c0.412 0.355 0.779 1.057 0.779 2.131c0 1.539-0.014 2.78-0.014 3.158c0 0.308 0.207 0.666 0.793 0.553C20.712 21.391 24 17.08 24 12c0-6.351-5.149-11.5-11.5-11.5Z"
              />
            </svg>
          </a>
          <button
            type="button"
            id="run-feedback-toggle"
            class="run-feedback-toggle"
            aria-label="Run sound and animations on"
            aria-pressed="true"
            title="Turn off run sound and animations"
          >
            <span class="run-feedback-toggle__glyph" aria-hidden="true">♭</span>
          </button>
        </div>
      </header>
      <script>
      import { getLegacyRouteRedirectUrl } from "../client/location-search.ts";
      import {
        loadRunFeedbackPreference,
        syncRunFeedbackToggleButton,
        toggleRunFeedback,
      } from "../client/run-feedback.ts";

      function syncLegacyHashRouting() {
        const legacyRedirectUrl = getLegacyRouteRedirectUrl(window.location);
        if (legacyRedirectUrl) {
          window.location.replace(legacyRedirectUrl);
          return true;
        }
        return false;
      }

      if (!syncLegacyHashRouting()) {
        loadRunFeedbackPreference();

        const runFeedbackToggle = document.querySelector("#run-feedback-toggle");
        if (runFeedbackToggle instanceof HTMLButtonElement) {
          syncRunFeedbackToggleButton(runFeedbackToggle);
          runFeedbackToggle.addEventListener("click", () => {
            toggleRunFeedback();
            syncRunFeedbackToggleButton(runFeedbackToggle);
          });
        }

        window.addEventListener("hashchange", () => {
          syncLegacyHashRouting();
        });
      }
      </script>
      <slot />
    </main>
  </body>
</html>
