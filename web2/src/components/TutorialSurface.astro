---
import TutorialIntro from "./TutorialIntro.astro";
---

<TutorialIntro />

<section class="page-section">
  <div id="tutorial-surface-root"></div>
</section>

<script>
  import { mountTutorialSurface } from "../client/mount-tutorial.ts";

  const root = document.querySelector("#tutorial-surface-root");
  if (root instanceof HTMLElement) {
    mountTutorialSurface(root);
  }
</script>
