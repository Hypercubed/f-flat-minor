---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteSections } from "../data/site";
---

<BaseLayout
  title="F-flat-minor"
  description="The Astro-based home for the F-flat-minor website, with interactive tools mounted on dedicated routes."
  theme="home"
  activePath="/"
>
  <section class="hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">f-flat-minor</p>
      <h1 class="hero-title">Run, explore, and learn F♭m in the browser.</h1>
      <p class="hero-lede">
        The Astro site brings together the browser playground, REPL, codettas, tutorials, and reference
        material on dedicated routes with a shared shell and consistent navigation.
      </p>
      <div class="hero-actions">
        <a class="button-link primary" href="/playground/">Open the playground</a>
        <a class="button-link secondary" href="/help/">Read the reference</a>
      </div>
      <div class="migration-note">
        <p>Everything now lives under the Astro site shell, from interactive tools to reference content.</p>
      </div>
    </div>

    <aside class="hero-panel">
      <p class="eyebrow">What you can do here</p>
      <h2>Interactive tools and reference pages in one place.</h2>
      <ol class="stack">
        <li><strong>Shared layout</strong> for nav, branding, and page chrome</li>
        <li><strong>Dedicated routes</strong> for the main tool areas</li>
        <li><strong>Global styling</strong> lifted from the current warm glassmorphism palette</li>
        <li><strong>Interactive routes</strong> for Playground, REPL, Codettas, and Tutorial</li>
      </ol>
    </aside>
  </section>

  <section class="page-section grid feature-grid" aria-label="Site sections">
    {
      siteSections.map((section) => (
        <article class="feature-card">
          <p class="eyebrow">{section.eyebrow}</p>
          <h3>{section.title}</h3>
          <p>{section.summary}</p>
          <footer>
            <a class="inline-link" href={`/${section.slug}/`}>
              Open the {section.title.toLowerCase()} route
            </a>
          </footer>
        </article>
      ))
    }
  </section>
</BaseLayout>
