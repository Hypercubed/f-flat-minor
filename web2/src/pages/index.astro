---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteSections } from "../data/site";
---

<BaseLayout
  title="F-flat-minor"
  description="The Astro-based home for the F-flat-minor website, with interactive tools mounted on dedicated routes."
  theme="home"
  activePath="/"
>
  <section class="hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">f-flat-minor</p>
      <h1 class="hero-title">Bring the F♭m site into Astro without losing its voice.</h1>
      <p class="hero-lede">
        Astro now owns the site shell and route structure while the existing interactive playground, REPL,
        codettas, and tutorials are mounted inside those routes with their current <code>lit-html</code>
        rendering intact.
      </p>
      <div class="hero-actions">
        <a class="button-link primary" href="/playground/">Browse the new routes</a>
        <a class="button-link secondary" href="/help/">See the easiest migration target</a>
      </div>
      <div class="migration-note">
        <p>Astro now owns the site shell, page routing, and reference content while the browser tools run inside dedicated routes.</p>
      </div>
    </div>

    <aside class="hero-panel">
      <p class="eyebrow">What ships now</p>
      <h2>Astro shell, interactive tools included.</h2>
      <ol class="stack">
        <li><strong>Shared layout</strong> for nav, branding, and page chrome</li>
        <li><strong>Dedicated routes</strong> for the main tool areas</li>
        <li><strong>Global styling</strong> lifted from the current warm glassmorphism palette</li>
        <li><strong>Interactive routes</strong> for Playground, REPL, Codettas, and Tutorial</li>
      </ol>
    </aside>
  </section>

  <section class="page-section grid feature-grid" aria-label="Site sections">
    {
      siteSections.map((section) => (
        <article class="feature-card">
          <p class="eyebrow">{section.eyebrow}</p>
          <h3>{section.title}</h3>
          <p>{section.summary}</p>
          <footer>
            <a class="inline-link" href={`/${section.slug}/`}>
              Open the {section.title.toLowerCase()} route
            </a>
          </footer>
        </article>
      ))
    }
  </section>
</BaseLayout>
