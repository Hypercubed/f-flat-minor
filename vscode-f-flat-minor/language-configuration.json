{
  "comments": {
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    ["[", "]"],
    ["{", "}"]
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["{", "}"]
  ],
  "indentationRules": {
    "increaseIndentPattern": ".*:$",
    "decreaseIndentPattern": "^\\s*;.*$"
  },
  "wordPattern": "[']?[^\\s\\[\\]\\{\\}:;]+[']?"
}
