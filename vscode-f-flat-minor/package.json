{
  "name": "vscode-f-flat-minor",
  "displayName": "F♭m (f-flat-minor) Language Support",
  "description": "Syntax highlighting and language support for f-flat-minor, a minimal stack-oriented programming language",
  "version": "0.0.6",
  "publisher": "hypercubed",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:f-flat-minor",
    "onCommand:f-flat-minor.auditCurrentDefinition"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Hypercubed/f-flat-minor"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "vsce": "^2.0.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "f-flat-minor.auditCurrentDefinition",
        "title": "F-flat-minor: Audit Current Definition"
      }
    ],
    "languages": [
      {
        "id": "f-flat-minor",
        "aliases": ["F♭m", "f-flat-minor", "ff", "ffp"],
        "extensions": [".ff", ".ffp"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "f-flat-minor",
        "scopeName": "source.f-flat-minor",
        "path": "./syntaxes/ff.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": ["meta.preprocessor.f-flat-minor"],
            "settings": {
              "foreground": "#808080",
              "fontStyle": "italic"
            }
          },
          {
            "scope": ["meta.compiler.annotation.f-flat-minor"],
            "settings": {
              "foreground": "#808080"
            }
          }
        ]
      }
    }
  }
}
