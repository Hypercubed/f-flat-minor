{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "F♭m",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#directives"
    },
    {
      "include": "#definitions"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#brackets"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.f-flat-minor",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.f-flat-minor",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.f-flat-minor",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.f-flat-minor",
          "match": "\\b(0x[0-9a-fA-F_]+|0b[01_]+|0o[0-7_]+|[0-9][0-9_]*)\\b"
        }
      ]
    },
    "directives": {
      "name": "keyword.directive.f-flat-minor",
      "match": "\\.[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "definitions": {
      "name": "variable.definition.f-flat-minor",
      "match": "[a-zA-Z_][a-zA-Z0-9_]*:"
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.f-flat-minor",
          "match": "(?i)\\b(?:dup|drop|swap|eval|nop|putc|getc|putn|clock|clr|rand|exit|depth|q<|q>)\\b"
        }
      ]
    },
    "brackets": {
      "patterns": [
        {
          "name": "punctuation.definition.quote.begin.f-flat-minor",
          "match": "\\["
        },
        {
          "name": "punctuation.definition.quote.end.f-flat-minor",
          "match": "\\]"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.f-flat-minor",
          "match": "[+\\-*/%=<>]|[|&~]|[<>][<>]?|\\?|:|;|\\(|\\)"
        }
      ]
    }
  },
  "scopeName": "source.f-flat-minor"
}
