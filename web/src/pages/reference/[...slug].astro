---
import { getCollection, render } from "astro:content";
import ReferenceContent from "../../components/ReferenceContent.astro";
import { getDocsSidebarGroups, getDocsSlug } from "../../data/docs";

export async function getStaticPaths() {
  const pages = await getCollection("docs");

  return pages
    .filter((page) => getDocsSlug(page) !== "")
    .map((page) => ({
      params: { slug: getDocsSlug(page) },
    }));
}

const slug = Astro.params.slug;
const page = slug ? (await getCollection("docs")).find((entry) => getDocsSlug(entry) === slug) : undefined;

if (!page) {
  throw new Error("Missing reference page.");
}

const sidebarGroups = await getDocsSidebarGroups();
const { Content } = await render(page);
---

<ReferenceContent page={page} sidebarGroups={sidebarGroups} Content={Content} />
