---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getDocsRoutePath, type DocsEntry, type DocsSidebarGroup } from "../data/docs";
import { withBasePath } from "../data/site";

interface Props {
  page: DocsEntry;
  sidebarGroups: DocsSidebarGroup[];
  Content: any;
}

const { page, sidebarGroups, Content } = Astro.props;
const pageRoutePath = getDocsRoutePath(page);
---

<BaseLayout
  title={page.data.title}
  description={page.data.summary || "Language reference documentation for F-flat-minor."}
  theme="reference"
  activePath="/reference/"
>
  <section class="route-hero section-summary">
    <p class="eyebrow">Language docs</p>
    <h1 class="route-title">{page.data.title}</h1>
    <p class="page-copy">
      {page.data.summary || "Reference docs rendered from the source-authored Markdown pages in the repository."}
    </p>
  </section>

  <section class="page-section reference-layout">
    <aside class="panel reference-nav-panel" aria-label="Reference navigation">
      <div class="panel-header">
        <div>
          <h2>Contents</h2>
        </div>
      </div>
      <div class="help-copy reference-nav-copy">
        <nav class="reference-doc-nav" aria-label="Reference document navigation">
          {
            sidebarGroups.map((group) => (
              <section class="reference-nav-group">
                <p class="reference-nav-group-label">{group.label}</p>
                {group.entries.map((entry) => (
                  <a
                    class:list={["reference-doc-link", getDocsRoutePath(entry) === pageRoutePath && "is-active"]}
                    href={withBasePath(getDocsRoutePath(entry))}
                  >
                    <span>{entry.data.title}</span>
                    {entry.data.summary && <small>{entry.data.summary}</small>}
                  </a>
                ))}
              </section>
            ))
          }
        </nav>
      </div>
    </aside>

    <article class="panel reference-doc-panel">
      <div class="reference-doc-body">
        <Content />
      </div>
    </article>
  </section>
</BaseLayout>
