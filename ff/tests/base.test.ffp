.import ../lib/core/core.ff
.import ../lib/tap.ffp

TAP-VERSION

'\0Shuffling' SUBTEST
    3 dup 3 = [ 3 = ] dip and OK
    1 PLAN OK

'\0Basic\sMath' SUBTEST
    1 2 + 3 = OK
    3 4 - -1 = OK
    5 6 * 30 = OK
    8 4 / 2 = OK
    8 5 % 3 = OK
    9 12 ^ 282429536481 = OK
    6 PLAN OK

'\0Large\sPowers' SUBTEST
    5 4 3 2 ^ ^ ^ 10 10 ^ % 8212890625 = OK
    1 PLAN OK

'\0Bitwise' SUBTEST
    5 3 & 1 = OK
    5 3 | 7 = OK
    5 ~ -6 = OK
    3 PLAN OK

'\0Comparison' SUBTEST
    1 2 < OK
    2 2 < not OK
    4 3 < not OK
    5 6 > not OK
    6 6 > not OK
    8 7 > OK
    9 10 = not OK
    10 10 = OK
    8 PLAN OK

'\0Control\sFlow' SUBTEST
    5 true [ 3 + ] ? 8 = OK
    5 false [ 3 + ] ? 5 = OK
    2 PLAN OK

6 PLAN
