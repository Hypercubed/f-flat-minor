.import ../lib/core/core.ff
.import ../lib/tap.ffp

TAP-VERSION

'\0Numeric' SUBTEST
    /* TODO: cpp
    0b1111 15 assert_eq
    0xFFFF 65535 assert_eq
    0o27 23 assert_eq
    1_000_000 1000000 assert_eq
    0b1110_0000_0000_0000 57344 assert_eq */

    /* TODO: cpp, python
    -0b1111 -15 assert_eq
    -0xFFFF -65535 assert_eq
    -0o27 -23 assert_eq
    -1_000_000 -1000000 assert_eq
    -0b1110_0000_0000_0000 -57344 assert_eq */

    /* TODO: cpp
    1e10 10000000000 assert_eq
    -1e10 -10000000000 assert_eq */
    0 PLAN OK

'\0Characters' SUBTEST
    'A' 65 = OK
    'a' 97 = OK

    '\s' 32 = OK
    '\n' 10 = OK
    4 PLAN OK

'\0Strings' SUBTEST
  'abc' rot 'a' = [ 'b' = [ 'c' = ] dip and ] dip and OK
  1 PLAN OK

3 PLAN
