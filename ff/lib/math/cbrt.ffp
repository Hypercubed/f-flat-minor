.import ./arith.ffp

/*
 * Naming note: the `i` prefix means integer.
 * `icbrt` returns the integer cube root (truncated toward zero).
 */

__cbrt__closer: dup2 2 ^ / over 2 * + 3 / ;
__cbrt__loop: __cbrt__closer dup2 > [ nip __cbrt__loop ] ? ;
__cbrt__cbrtn: dup 3 / __cbrt__loop drop nip ;

icbrt: dup sgn swap over * dup 1 > [ __cbrt__cbrtn ] ? * ;
