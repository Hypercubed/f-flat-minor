.import ./arith.ffp

/*
 * Naming note: the `i` prefix means integer.
 * `icbrt` returns the integer cube root (truncated toward zero).
 */

_cbrt__closer: dup2 2 ^ / over 2 * + 3 / ;
_cbrt__loop: _cbrt__closer dup2 > [ nip _cbrt__loop ] ? ;
_cbrt__cbrtn: dup 3 / _cbrt__loop drop nip ;

icbrt: dup sgn swap over * dup 1 > [ _cbrt__cbrtn ] ? * ;
