.import ./atan-core.ffp

__guard_digits: 20 ;


/* n -> floor(pi * 10^n) */
npi:
  __guard_digits +
  dup 1 5 _atan__core_scaled
  swap 1 239 _atan__core_scaled
  swap 4 * swap -
  4 *
  __guard_digits n->S /
; /* n _npi__ == floor(10^n*pi) */

tau:
  dup npi 2 *
; /* n tau == floor(10^n*2*pi) */

half_pi:
  dup npi 2 /
; /* n half_pi == floor(10^n*pi/2) */