.import ./atan-core.ffp

_pi__pi_guard_digits: 20 ;


/* n -> floor(pi * 10^n) */
npi:
  _pi__pi_guard_digits +
  dup 1 5 _atan__core_scaled
  swap 1 239 _atan__core_scaled
  swap 4 * swap -
  4 *
  _pi__pi_guard_digits n->S /
; /* n _npi__ == floor(10^n*pi) */

_trig__tau:
  dup npi 2 *
; /* n _trig__tau == floor(10^n*2*pi) */

_trig__half_pi:
  dup npi 2 /
; /* n _trig__half_pi == floor(10^n*pi/2) */