.import ../trig.ffp
.import ../pi.ffp
.import ../../tap.ffp

/* Temporary placeholders so skipped trig tests compile until trig.ffp
 * defines these words. Remove these local definitions once real
 * implementations exist in the library.
 */
ncos: drop2 0 ;
nsin: drop2 0 ;

TAP-VERSION

'\0ncos-nsin' SUBTEST
  5 0 ncos 100_000 = #TODO
  5 0 nsin 0 = #TODO
  5 1 ncos 54_030 = #TODO
  5 1 nsin 84_147 = #TODO
  5 -1 ncos 54_030 = #TODO
  5 -1 nsin -84_148 = #TODO
  5 2 ncos -41_615 = #TODO
  5 2 nsin 90_929 = #TODO
  8 PLAN
OK

'\0periodicity-and-symmetry' SUBTEST
  5 7 ncos 75_390 = #TODO
  5 7 nsin 65_698 = #TODO
  5 -7 ncos 75_390 = #TODO
  5 -7 nsin -65_699 = #TODO
  4 PLAN
OK

2 PLAN
