.import ../atanh.ffp
.import ../../tap.ffp

TAP-VERSION

'\0iatanh' SUBTEST
  0 iatanh 0 = OK
  1 PLAN OK

'\0natanh' SUBTEST
  0 0 natanh 0 = OK
  5 0 natanh 0 = OK
  20 0 natanh 0 = OK
  3 PLAN OK

'\0qatanh' SUBTEST
  0 1 qatanh 0 = OK
  1 3 qatanh 0 = OK
  -1 3 qatanh -1 = OK
  1 -3 qatanh -1 = OK
  -1 -3 qatanh 0 = OK
  4 5 qatanh 1 = OK
  -4 5 qatanh -2 = OK
  7 PLAN OK

'\0atanh-inv' SUBTEST
  5 3 atanh-inv 34_657 = OK
  20 3 atanh-inv 34_657_359_027_997_265_470 = OK
  5 -3 atanh-inv -34_658 = OK
  5 2 atanh-inv 54_930 = OK
  4 PLAN OK

4 PLAN
