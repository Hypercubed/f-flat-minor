.import ../sqrt.ffp
.import ../../seq/seq.ffp
.import ../../tap.ffp

TAP-VERSION

'\0isqrt' SUBTEST
  0 isqrt 0 = OK
  1 isqrt 1 = OK
  2 isqrt 1 = OK
  3 isqrt 1 = OK
  4 isqrt 2 = OK
  25 isqrt 5 = OK
  125348 isqrt 354 = OK
  100 8 ^ 2 * isqrt 141421356 = OK
  8 PLAN OK

'\0isqrtrem' SUBTEST
  [ 1 isqrtrem ] in [ 1 0 ] seq= OK
  [ 2 isqrtrem ] in [ 1 1 ] seq= OK
  [ 3 isqrtrem ] in [ 1 2 ] seq= OK
  [ 4 isqrtrem ] in [ 2 0 ] seq= OK
  [ 7 isqrtrem ] in [ 2 3 ] seq= OK
  [ 9 isqrtrem ] in [ 3 0 ] seq= OK
  [ 11 isqrtrem ] in [ 3 2 ] seq= OK
  [ 24 isqrtrem ] in [ 4 8 ] seq= OK
  [ 25 isqrtrem ] in [ 5 0 ] seq= OK
  [ 26 isqrtrem ] in [ 5 1 ] seq= OK
  [ 1048576 isqrtrem ] in [ 1024 0 ] seq= OK
  11 PLAN OK

'\0nsqrt' SUBTEST
  0 0 nsqrt 0 = OK
  0 2 nsqrt 1 = OK
  1 2 nsqrt 14 = OK
  3 2 nsqrt 1414 = OK
  2 81 nsqrt 900 = OK
  5 PLAN OK

3 PLAN
