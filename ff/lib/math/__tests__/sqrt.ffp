.import ../sqrt.ffp
.import ../../testing.ffp

0 'isqrt' prints
    0 isqrt 0 assert_eq
    1 isqrt 1 assert_eq
    2 isqrt 1 assert_eq
    3 isqrt 1 assert_eq
    4 isqrt 2 assert_eq
    25 isqrt 5 assert_eq
    125348 isqrt 354 assert_eq
    100 8 ^ 2 * isqrt 141421356 assert_eq
OK

0 'isqrtrem' prints
    1 isqrtrem 0 assert_eq 1 assert_eq
    2 isqrtrem 1 assert_eq 1 assert_eq
    3 isqrtrem 2 assert_eq 1 assert_eq
    4 isqrtrem 0 assert_eq 2 assert_eq
    7 isqrtrem 3 assert_eq 2 assert_eq
    9 isqrtrem 0 assert_eq 3 assert_eq
    11 isqrtrem 2 assert_eq 3 assert_eq
    24 isqrtrem 8 assert_eq 4 assert_eq
    25 isqrtrem 0 assert_eq 5 assert_eq
    26 isqrtrem 1 assert_eq 5 assert_eq
    1048576 isqrtrem 0 assert_eq 1024 assert_eq
OK

0 'nsqrt' prints
    0 0 nsqrt 0 assert_eq
    0 2 nsqrt 1 assert_eq
    1 2 nsqrt 14 assert_eq
    3 2 nsqrt 1414 assert_eq
    2 81 nsqrt 900 assert_eq
OK
