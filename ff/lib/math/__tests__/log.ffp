    16 iln 2 assert_eq
    1024 iln 6 assert_eq
    65536 iln 11 assert_eq
    123456789 iln 18 assert_eq
    120 ! iln 457 assert_eq
    52656145834278593348959013841835216159447547700274555627155488768 iln 149 assert_eq
OK

