.import ../prn.ffp
.import ../pi.ffp
.import ../../string/string.ffp
.import ../exp.ffp

N: 100 ;
S: 10 N ^ ; /* 10^31 */

P: N npi ; /* 10^31 * pi */
E: N 1 nexp ; /* 10^31 * e */

'\0pi\s=\s' prints
P N nputn
cr

'\0e\s=\s' prints
E N nputn
cr

'\0123004/1000\s=\s' prints
123004 3 nputn
cr

'\01/1000\s=\s' prints
1 3 nputn
cr

'\0120000/1000\s=\s' prints
120000 3 nputn
cr

'\049/21\s=\s' prints
49 21 qputn
