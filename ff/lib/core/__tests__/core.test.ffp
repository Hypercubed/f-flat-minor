.import ../core.ff
.import ../../seq/seq.ffp
.import ../../tap.ffp

TAP-VERSION

'\0Shuffling' SUBTEST
  [ 3 5 dup2 ] in [ 3 5 3 5 ] seq= OK
  [ 1 2 3 bury ] in [ 3 1 2 ] seq= OK
  [ 1 2 3 rot ] in [ 3 2 1 ] seq= OK
  [ 5 [ 2 * ] [ 2 + ] bi ] in [ 10 7 ] seq= OK
  4 PLAN OK

'\0Logical' SUBTEST
  true true and OK
  true false and not OK
  false true and not OK
  false false and not OK

  true true or OK
  true false or OK
  false true or OK
  false false or not OK
  8 PLAN OK

'\0Comparison' SUBTEST
  1 2 <= OK
  2 2 <= OK
  6 6 >= OK
  8 7 >= OK
  8 7 != OK

  1 3 2 between? OK
  3 1 2 between? OK
  1 2 3 between? not OK
  3 2 1 between? not OK
  9 PLAN OK

'\0Control\sFlow' SUBTEST
  true 5 8 choose 5 = OK
  false 5 8 choose 8 = OK

  5 true [ 3 + ] [ 3 - ] branch 8 = OK
  5 false [ 3 + ] [ 3 - ] branch 2 = OK
  4 PLAN OK

4 PLAN
