/* String output */

__prints: dup [ q< __prints q> putc ] ? ; /* 0 n* __prints == 0 {prints chars} */
prints: __prints drop ; /* 0 n* prints == {prints chars} */
println: prints cr ; /* 0 n* println == {prints chars, char(10)} */

__lens: dup [ q< __lens q> drop 1 + ] ? ;

sprint: 0 swap eval prints ;
sprintln: sprint cr ;
slen: 0 swap eval __lens ;
scat: compose ;
sjoin: swap compose compose ;
cjoin: swap cons compose ;